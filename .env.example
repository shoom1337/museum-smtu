# === Database ===
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# === WordPress security keys ===
# Сгенерировать: https://api.wordpress.org/secret-key/1.1/salt/
WORDPRESS_AUTH_KEY=put_unique_phrase_here
WORDPRESS_SECURE_AUTH_KEY=put_unique_phrase_here
WORDPRESS_LOGGED_IN_KEY=put_unique_phrase_here
WORDPRESS_NONCE_KEY=put_unique_phrase_here
WORDPRESS_AUTH_SALT=put_unique_phrase_here
WORDPRESS_SECURE_AUTH_SALT=put_unique_phrase_here
WORDPRESS_LOGGED_IN_SALT=put_unique_phrase_here
WORDPRESS_NONCE_SALT=put_unique_phrase_here

# === Порты ===
WP_PORT=8000    # WordPress доступен на <IP>:8000
PMA_PORT=8080   # phpMyAdmin доступен на <IP>:8080
